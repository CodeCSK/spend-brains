# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=3000

# PostgreSQL — local Docker: docker compose up -d (repo root)
DATABASE_URL="postgresql://spendbrains:spendbrains@localhost:5432/spendbrains?schema=public"

# JWT — use long random strings in staging/production (min 32 chars)
JWT_ACCESS_SECRET=change-me-local-dev-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-local-dev-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# MSG91 OTP (India) — placeholders until DLT + production keys
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=SPBRNS
MSG91_OTP_TEMPLATE_ID=your-dlt-otp-template-id

# OTP policy (5–10 min TTL per security spec)
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PHONE_PER_HOUR=3
OTP_RATE_LIMIT_IP_PER_HOUR=10

# Cloudflare Turnstile (web CAPTCHA before OTP send)
# Set TURNSTILE_ENABLED=true in production
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# Optional: fixed OTP for local dev (never set in production)
# OTP_FIXED_CODE=123456

# Friends beta on staging: OTP = last 6 digits of phone (+919876543210 → 543210)
# OTP_USE_PHONE_SUFFIX=true

# CORS — comma-separated origins for the web SPA
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
