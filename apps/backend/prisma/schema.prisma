// Spendbrains database schema — see apps/backend/docs/database/schema.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EventType {
  general
  vacation
  corporate
  ritual
  roommate
  travel
  party

  @@map("event_type")
}

enum EventVisibility {
  private
  public

  @@map("event_visibility")
}

enum MemberRole {
  captain
  vice_captain
  member

  @@map("member_role")
}

enum JoinRequestStatus {
  pending
  approved
  rejected

  @@map("join_request_status")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  phone           String    @unique @db.VarChar(15)
  phoneVerifiedAt DateTime? @map("phone_verified_at") @db.Timestamptz(6)
  displayName     String?   @map("display_name") @db.VarChar(100)
  avatarUrl       String?   @map("avatar_url")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  refreshTokens     RefreshToken[]
  captainedEvents   Event[]          @relation("EventCaptain")
  memberships       EventMember[]
  joinRequests      JoinRequest[]    @relation("JoinRequestUser")
  reviewedRequests  JoinRequest[]    @relation("JoinRequestReviewer")
  createdExpenses   Expense[]        @relation("ExpenseCreatedBy")
  paidExpenses      Expense[]        @relation("ExpensePaidBy")
  expenseShares     ExpenseShare[]
  settlementsFrom   SettlementLine[] @relation("SettlementFrom")
  settlementsTo     SettlementLine[] @relation("SettlementTo")
  settledLines      SettlementLine[] @relation("SettlementSettledBy")

  @@map("users")
}

model Event {
  id            String          @id @default(uuid()) @db.Uuid
  publicId      String          @unique @map("public_id") @db.VarChar(8)
  name          String          @db.VarChar(200)
  description   String?         @db.Text
  location      String?         @db.VarChar(300)
  startDate     DateTime        @map("start_date") @db.Date
  endDate       DateTime        @map("end_date") @db.Date
  eventType     EventType       @default(general) @map("event_type")
  coverImageUrl String?         @map("cover_image_url") @db.Text
  visibility    EventVisibility @default(private)
  isArchived    Boolean         @default(false) @map("is_archived")
  captainId     String          @map("captain_id") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  captain         User                   @relation("EventCaptain", fields: [captainId], references: [id], onDelete: Restrict)
  members         EventMember[]
  joinRequests    JoinRequest[]
  categories      EventExpenseCategory[]
  expenses        Expense[]
  settlementLines SettlementLine[]

  @@index([captainId])
  @@map("events")
}

model EventMember {
  id        String     @id @default(uuid()) @db.Uuid
  eventId   String     @map("event_id") @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  role      MemberRole @default(member)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@map("event_members")
}

model JoinRequest {
  id         String            @id @default(uuid()) @db.Uuid
  eventId    String            @map("event_id") @db.Uuid
  userId     String            @map("user_id") @db.Uuid
  status     JoinRequestStatus @default(pending)
  reviewedBy String?           @map("reviewed_by") @db.Uuid
  reviewedAt DateTime?         @map("reviewed_at") @db.Timestamptz(6)
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User  @relation("JoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("JoinRequestReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([eventId, status])
  @@index([userId])
  @@map("join_requests")
}

model EventExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  name      String   @db.VarChar(50)
  icon      String   @db.VarChar(50)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@index([eventId])
  @@map("event_expense_categories")
}

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  createdBy   String   @map("created_by") @db.Uuid
  description String   @db.VarChar(500)
  amount      Decimal  @db.Decimal(12, 2)
  paidBy      String   @map("paid_by") @db.Uuid
  expenseDate DateTime @map("expense_date") @db.Date
  categoryId  String   @map("category_id") @db.Uuid
  notes       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  event    Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  creator  User                 @relation("ExpenseCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  payer    User                 @relation("ExpensePaidBy", fields: [paidBy], references: [id], onDelete: Restrict)
  category EventExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  shares   ExpenseShare[]

  @@index([eventId])
  @@index([categoryId])
  @@index([paidBy])
  @@map("expenses")
}

model ExpenseShare {
  id        String   @id @default(uuid()) @db.Uuid
  expenseId String   @map("expense_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@index([userId])
  @@map("expense_shares")
}

model SettlementLine {
  id                  String    @id @default(uuid()) @db.Uuid
  eventId             String    @map("event_id") @db.Uuid
  fromUserId          String    @map("from_user_id") @db.Uuid
  toUserId            String    @map("to_user_id") @db.Uuid
  amount              Decimal   @db.Decimal(12, 2)
  isSettled           Boolean   @default(false) @map("is_settled")
  settledBy           String?   @map("settled_by") @db.Uuid
  settledAt           DateTime? @map("settled_at") @db.Timestamptz(6)
  computationVersion  Int       @default(1) @map("computation_version")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fromUser User  @relation("SettlementFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User  @relation("SettlementTo", fields: [toUserId], references: [id], onDelete: Cascade)
  settler  User? @relation("SettlementSettledBy", fields: [settledBy], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("settlement_lines")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model OtpCode {
  id         String    @id @default(uuid()) @db.Uuid
  phone      String    @db.VarChar(15)
  codeHash   String    @map("code_hash") @db.VarChar(64)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  attempts   Int       @default(0)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([phone, createdAt])
  @@index([ipAddress, createdAt])
  @@map("otp_codes")
}
