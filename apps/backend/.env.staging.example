# Copy to .env.staging — run backend locally against Neon / beta settings.
# Live Fly.io API uses: fly secrets set (not this file).
# Switch: npm run start:dev:staging

NODE_ENV=staging
PORT=3000

# Neon PostgreSQL (ssl required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Generate: openssl rand -base64 32 (min 32 chars each)
JWT_ACCESS_SECRET=replace-with-random-string-at-least-32-chars
JWT_REFRESH_SECRET=replace-with-another-random-string-32-chars

# Placeholder key — SMS skipped in friends beta (OTP = last 6 digits of phone)
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=SPBRNS
MSG91_OTP_TEMPLATE_ID=your-dlt-otp-template-id

# Beta login: OTP is the last 6 digits of the user's phone (+919876543210 → 543210)
OTP_USE_PHONE_SUFFIX=true

# Comma-separated — set after Cloudflare Pages URL is known
CORS_ORIGINS=https://spend-brains.pages.dev,http://localhost:5173

TURNSTILE_ENABLED=false

# Dev console — comma-separated E.164 phones (same as local .env)
# Example: SUPER_ADMIN_PHONES=+919876543210
SUPER_ADMIN_PHONES=
